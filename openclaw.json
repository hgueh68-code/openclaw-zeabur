{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowedOrigins": [
        "https://hgus7089-openclaw.hf.space",
        "https://huggingface.co"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama_primary/qwen3.5:397b-cloud",
        "fallbacks": [
          "ollama_secondary/qwen3.5:397b-cloud",
          "ollama_primary/minimax-m2.5:cloud",
          "ollama_secondary/minimax-m2.5:cloud"
        ]
      },
      "models": {
        "ollama_primary/qwen3.5:397b-cloud": {
          "alias": "Ollama Key1 Qwen 3.5 397B"
        },
        "ollama_secondary/qwen3.5:397b-cloud": {
          "alias": "Ollama Key2 Qwen 3.5 397B"
        },
        "ollama_primary/minimax-m2.5:cloud": {
          "alias": "Ollama Key1 MiniMax M2.5"
        },
        "ollama_secondary/minimax-m2.5:cloud": {
          "alias": "Ollama Key2 MiniMax M2.5"
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "network": {
        "autoSelectFamily": false,
        "dnsResultOrder": "ipv4first"
      },
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama_primary": {
        "baseUrl": "https://ollama.com/v1",
        "apiKey": "${OLLAMA_API_KEY_1}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.5:397b-cloud",
            "name": "qwen3.5:397b-cloud"
          },
          {
            "id": "minimax-m2.5:cloud",
            "name": "minimax-m2.5:cloud"
          }
        ]
      },
      "ollama_secondary": {
        "baseUrl": "https://ollama.com/v1",
        "apiKey": "${OLLAMA_API_KEY_2}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.5:397b-cloud",
            "name": "qwen3.5:397b-cloud"
          },
          {
            "id": "minimax-m2.5:cloud",
            "name": "minimax-m2.5:cloud"
          }
        ]
      }
    }
  },
  "tools": {
    "deny": [
      "image"
    ],
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave",
        "maxResults": 5,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      },
      "fetch": {
        "enabled": true,
        "maxChars": 50000,
        "maxCharsCap": 50000,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      }
    }
  }
}

