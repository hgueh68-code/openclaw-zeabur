{
  "gateway": {
    "mode": "local"
  },
  "agent": {
    "model": {
      "primary": "sambanova/Meta-Llama-3.3-70B-Instruct"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "models": {
    "providers": {
      "sambanova": {
        "type": "openai",
        "baseUrl": "https://api.sambanova.ai/v1",
        "apiKeyEnv": "OPENAI_API_KEY"
      }
    }
  }
}