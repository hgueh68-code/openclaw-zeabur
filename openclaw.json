{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "sambanova/Meta-Llama-3.3-70B-Instruct"
      },
      "models": {
        "sambanova/Meta-Llama-3.3-70B-Instruct": {
          "alias": "Samba Llama 3.3 70B"
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "sambanova": {
        "baseUrl": "https://api.sambanova.ai/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "Meta-Llama-3.3-70B-Instruct",
            "name": "Meta-Llama-3.3-70B-Instruct"
          }
        ]
      }
    }
  }
}
